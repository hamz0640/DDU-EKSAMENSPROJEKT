HighlightSize = Vector2(180, 160)
metadata/_custom_type_script = "uid://do3ogi7c6uyy7"

[sub_resource type="Resource" id="Resource_5045t"]
script = ExtResource("5_71327")
Title = "Upgrade menu"
Description = "This is the upgrade menu. Here, you can buy or upgrade your gadgets. To navigate the menu, use W and S to move up or down, and press Space to purchase."
HighlightPosition = Vector2(90, 90)
HighlightSize = Vector2(1800, 900)
metadata/_custom_type_script = "uid://do3ogi7c6uyy7"

[sub_resource type="Resource" id="Resource_4e5ao"]
script = ExtResource("5_71327")
Title = "Ship Health"
Description = "This bar shows your ship's current health. It can be damaged by enemy bullets and other threats. Protect it at all costs, if your ship is destroyed, you automatically die."
HighlightPosition = Vector2(110, 120)
HighlightSize = Vector2(230, 100)
metadata/_custom_type_script = "uid://do3ogi7c6uyy7"

[sub_resource type="Resource" id="Resource_1fhva"]

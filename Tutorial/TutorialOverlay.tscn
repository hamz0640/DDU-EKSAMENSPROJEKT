Title = "Wire"
Description = "You can go down to the mines using the wire by pressing space."
HighlightPosition = Vector2(120, 290)
HighlightSize = Vector2(380, 360)
metadata/_custom_type_script = "uid://do3ogi7c6uyy7"

[sub_resource type="Resource" id="Resource_mf4nu"]

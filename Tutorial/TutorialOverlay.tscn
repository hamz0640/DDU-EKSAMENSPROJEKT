[sub_resource type="Resource" id="Resource_ov3gm"]
script = ExtResource("5_71327")
Title = "You"
Description = "This is you. You can move around using WASD. You can fly using your jetpack by pressing the spacebar, but be aware of its energy consumption. You can mine by moving in the direction of a block."
HighlightPosition = Vector2(880, 440)
HighlightSize = Vector2(160, 170)
metadata/_custom_type_script = "uid://do3ogi7c6uyy7"

[sub_resource type="Resource" id="Resource_71327"]
script = ExtResource("5_71327")
Title = "Ship"
Description = "This is your main ship, protect it at all costs from enemies and other hostile creatures."
HighlightPosition = Vector2(575, 110)
HighlightSize = Vector2(1000, 500)
metadata/_custom_type_script = "uid://do3ogi7c6uyy7"

[sub_resource type="Resource" id="Resource_87rfo"]
script = ExtResource("5_71327")
Title = "Shield"
Description = "The blue shield around your base protects you from enemies and asteroids, but be aware that it can be destroyed. It also works as a charging zone for your energy."
HighlightPosition = Vector2(177, -11)
HighlightSize = Vector2(100, 100)
metadata/_custom_type_script = "uid://do3ogi7c6uyy7"

[sub_resource type="Resource" id="Resource_2arwq"]
script = ExtResource("5_71327")
Title = "Energy"
Description = "This bar shows your current energy level. Mining minerals using the jetpack consumes energy. Be aware that if you run out of energy, you will die. Remember, you can always recharge as long as you are in the charging zone."
HighlightPosition = Vector2(15, 130)
HighlightSize = Vector2(300, 120)
metadata/_custom_type_script = "uid://do3ogi7c6uyy7"

[sub_resource type="Resource" id="Resource_a3eon"]
